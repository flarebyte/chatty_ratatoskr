# Node / general JS deps
node_modules/

# Dev-only binaries
.e2e-bin/
/thoth

# Go cache
.gocache/
.gomodcache/
.cache/
.golangci-lint-cache/

# Local GOPATH when sandboxed
_gopath/

# Script dependencies
script/node_modules/

# Bun caches and outputs
.bun/
bun.lockb.tmp
bun-cache/
dist/
build/

# ZX / transient execution artifacts
.zx/
tmp/
*.log

# TypeScript incremental builds
*.tsbuildinfo

# Editors
# VS Code (commit team config, ignore transient state if created)
.vscode/*.log

# Sublime (commit project, ignore session state)
*.sublime-workspace

# Lapce (commit settings if standardized; ignore caches if added later)
.lapce/db/

# Generic editor swaps/backups
*.swp
*.swo
*~
