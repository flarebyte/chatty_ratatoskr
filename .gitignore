*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries and artifacts
*.test
*.out
coverage.*
*.coverprofile
profile.cov

# Generated dependencies (ignore by default; delete if vendoring is committed)
vendor/

# Workspace
go.work
go.work.sum

# Local env
.env

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux / freedesktop
.directory
.Trash-*

# Build and temp
build/
temp/
scratch/
